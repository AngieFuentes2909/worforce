{
  "version": 2,
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/(css|js|img|responsive)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "src": "/produccion1/(assests|custom)/(.*)",
      "dest": "/produccion1/$1/$2"
    },
    {
      "src": "/produccion1",
      "dest": "/api/produccion1/index.php"
    },
    {
      "src": "/produccion1/",
      "dest": "/api/produccion1/index.php"
    },
    {
      "src": "/produccion1/(.*\\.php)",
      "dest": "/api/produccion1/$1"
    },
    {
      "src": "/index.php",
      "dest": "/api/index.php"
    },
    {
      "src": "/$",
      "dest": "/api/index.php"
    },
    {
      "src": "/(.*\\.php)",
      "dest": "/api/$1"
    }
  ]
}
